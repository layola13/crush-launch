CRUSH_LAUNCH_BASE_URL=https://api.openai.com/v1
CRUSH_LAUNCH_MODEL=gpt-4o
# API Key Configuration: Specify either a single key via CRUSH_LAUNCH_API_KEY or multiple comma-separated keys.
# Multiple keys are accepted for compatibility; the first key is used because Crush owns request execution.
CRUSH_LAUNCH_API_KEY=
# CRUSH_LAUNCH_API_KEYS=

# Provider settings written into the generated temporary crush.json.
# Use openai-compat for most non-OpenAI OpenAI-compatible endpoints.
# Use openai when proxying directly to OpenAI.
# CRUSH_LAUNCH_PROVIDER_ID=crush-launch
# CRUSH_LAUNCH_PROVIDER_NAME=crush-launch
# CRUSH_LAUNCH_PROVIDER_TYPE=openai-compat
# CRUSH_LAUNCH_MODEL_NAME=

# Optional model metadata and defaults.
# CRUSH_LAUNCH_CONTEXT_WINDOW=128000
# CRUSH_LAUNCH_MAX_TOKENS=8192
# CRUSH_LAUNCH_REASONING_EFFORT=
# CRUSH_LAUNCH_CAN_REASON=1
# CRUSH_LAUNCH_SUPPORTS_IMAGES=1

# JSON object merged into provider.extra_headers, for example:
# CRUSH_LAUNCH_EXTRA_HEADERS={"HTTP-Referer":"https://example.com","X-Title":"crush-launch"}
# CRUSH_LAUNCH_VERBOSE=1
# CRUSH_BIN=crush
